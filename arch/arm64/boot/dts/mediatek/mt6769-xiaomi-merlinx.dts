/*
 * Device Tree for Redmi Note 9 (merlinx - non-NFC variant)
 * SoC: MediaTek MT6769Z (Helio G85)
 * Display: 1080x2340 DSI panel
 * Storage: eMMC 5.1
 * Touch: Novatek NT36672A
 */

/dts-v1/;
#include "mt6768.dtsi"
#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>

/ {
	model = "Xiaomi Redmi Note 9 (merlinx)";
	compatible = "xiaomi,merlinx", "mediatek,mt6768";

	memory@40000000 {
		device_type = "memory";
		reg = <0 0x40000000 0 0x100000000>; /* 4GB */
	};

	/* Backlight */
	backlight: backlight {
		compatible = "pwm-backlight";
		pwms = <&pwm0 0 50000>;
		brightness-levels = <0 32 64 96 128 160 192 224 255>;
		default-brightness-level = <6>;
	};

	/* Vibrator */
	vibrator: vibrator {
		compatible = "gpio-vibrator";
		enable-gpios = <&pio 77 GPIO_ACTIVE_HIGH>;
	};

	/* GPIO Keys */
	gpio-keys {
		compatible = "gpio-keys";
		power-key {
			label = "Power Key";
			gpios = <&pio 66 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_POWER>;
			wakeup-source;
		};
		vol-up {
			label = "Volume Up";
			gpios = <&pio 67 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_VOLUMEUP>;
			wakeup-source;
		};
		vol-down {
			label = "Volume Down";
			gpios = <&pio 68 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_VOLUMEDOWN>;
			wakeup-source;
		};
	};

	/* LED indicators */
	leds {
		compatible = "gpio-leds";
		status-led {
			label = "merlinx:status:amber";
			gpios = <&pio 145 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};
	};
};

/* eMMC */
&mmc0 {
	bus-width = <8>;
	max-frequency = <200000000>;
	cap-mmc-highspeed;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	non-removable;
	status = "okay";
};

/* USB */
&usb {
	dr_mode = "otg";
	status = "okay";
};

/* UART0 console */
&uart0 {
	status = "okay";
};
