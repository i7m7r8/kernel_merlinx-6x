/*
 * Device Tree for Redmi Note 9 (merlinx - non-NFC)
 * SoC: MediaTek MT6769Z (Helio G85)
 */

/dts-v1/;
#include "mt6768.dtsi"
#include <dt-bindings/input/input.h>

/ {
	model = "Xiaomi Redmi Note 9 (merlinx)";
	compatible = "xiaomi,merlinx", "mediatek,mt6768";

	memory@40000000 {
		device_type = "memory";
		reg = <0x00000000 0x40000000 0x00000001 0x00000000>; /* 4GB */
	};
};

&mmc0 {
	bus-width = <8>;
	cap-mmc-highspeed;
	non-removable;
};

&uart0 {
	status = "okay";
};
