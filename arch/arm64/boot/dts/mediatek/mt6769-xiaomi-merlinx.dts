/*
 * Device Tree for Redmi Note 9 (merlinx - non-NFC)
 * SoC: MediaTek MT6769Z (Helio G85)
 */

/dts-v1/;
#include "mt6768.dtsi"
#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>

/ {
	model = "Xiaomi Redmi Note 9 (merlinx)";
	compatible = "xiaomi,merlinx", "mediatek,mt6768";

	memory@40000000 {
		device_type = "memory";
		reg = <0 0x40000000 0 0x100000000>; /* 4GB */
	};

	gpio-keys {
		compatible = "gpio-keys";
		power-key {
			label = "Power Key";
			gpios = <&pio 66 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_POWER>;
			wakeup-source;
		};
	};
};

&mmc0 {
	bus-width = <8>;
	cap-mmc-highspeed;
	non-removable;
};

&uart0 {
	status = "okay";
};
