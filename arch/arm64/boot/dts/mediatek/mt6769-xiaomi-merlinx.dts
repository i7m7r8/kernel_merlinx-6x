/*
 * Device Tree for Redmi Note 9 (merlinx - non-NFC)
 * SoC: MediaTek MT6769Z (Helio G85)
 * Display: 1080x2340 Tianma DSI panel
 * Storage: eMMC 5.1 + SD card
 * USB: Type-C OTG
 * WiFi: MT7663 SDIO
 * Audio: MT6358 codec
 */

/dts-v1/;
#include "mt6768.dtsi"
#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/pwm/pwm.h>

/ {
	model = "Xiaomi Redmi Note 9 (merlinx)";
	compatible = "xiaomi,merlinx", "mediatek,mt6768";

	memory@40000000 {
		device_type = "memory";
		reg = <0x00000000 0x40000000 0x00000001 0x00000000>;
	};

	chosen {
		bootargs = "console=ttyS0,921600n1 earlycon=uart8250,mmio32,0x11002000,921600n8";
		stdout-path = "uart0:921600n8";
	};

	/* Backlight */
	backlight: backlight {
		compatible = "pwm-backlight";
		pwms = <&pwm0 0 50000 PWM_POLARITY_INVERTED>;
		brightness-levels = <0 32 64 96 128 160 192 224 255>;
		default-brightness-level = <6>;
	};

	/* Vibrator */
	vibrator: vibrator {
		compatible = "gpio-vibrator";
		enable-gpios = <&pinctrl 77 GPIO_ACTIVE_HIGH>;
	};

	/* LED indicators */
	leds {
		compatible = "gpio-leds";
		status-led {
			label = "merlinx:status:amber";
			gpios = <&pinctrl 145 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};
	};

	/* Audio sound card */
	sound: sound {
		compatible = "mediatek,mt6768-sound",
			     "mediatek,mt6779-sound";
		model = "mt6768-merlinx";
		audio-routing =
			"Earphone", "HPOL",
			"Earphone", "HPOR",
			"Speakers", "SPK",
			"Headset Mic", "HSREF";
	};
};

/* eMMC - 8-bit, HS400 */
&mmc0 {
	bus-width = <8>;
	max-frequency = <200000000>;
	cap-mmc-highspeed;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	non-removable;
	status = "okay";
};

/* SD Card / WiFi combo */
&mmc1 {
	bus-width = <4>;
	max-frequency = <50000000>;
	cap-sd-highspeed;
	cd-gpios = <&pinctrl 18 GPIO_ACTIVE_LOW>;
	status = "okay";

	/* MT7663 WiFi via SDIO slot */
	wifi@1 {
		compatible = "mediatek,mt7663s";
		reg = <1>;
		interrupt-parent = <&pinctrl>;
		interrupts = <146 IRQ_TYPE_LEVEL_LOW>;
		interrupt-names = "wifi";
	};
};

/* UART0 console */
&uart0 {
	status = "okay";
};

/* I2C0 - Touchscreen */
&i2c0 {
	status = "okay";
};

/* I2C1 - Sensors */
&i2c1 {
	status = "okay";
};

/* I2C2 - Camera sensors */
&i2c2 {
	status = "okay";

	/* Main camera: IMX686 64MP */
	imx686: camera@1a {
		compatible = "sony,imx686";
		reg = <0x1a>;
		enable-gpios = <&pinctrl 120 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&pinctrl 121 GPIO_ACTIVE_LOW>;
		af-gpios = <&pinctrl 122 GPIO_ACTIVE_HIGH>;
		flash-gpios = <&pinctrl 123 GPIO_ACTIVE_HIGH>;
		clocks = <&clk26m>;
		clock-names = "xvclk";
		assigned-clocks = <&clk26m>;
		assigned-clock-rates = <24000000>;
		port {
			imx686_ep: endpoint {
				remote-endpoint = <&seninf_ep0>;
				data-lanes = <1 2 3 4>;
				clock-lanes = <0>;
			};
		};
	};

	/* Ultra-wide: OV8856 8MP */
	ov8856: camera@36 {
		compatible = "ovti,ov8856";
		reg = <0x36>;
		enable-gpios = <&pinctrl 124 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&pinctrl 125 GPIO_ACTIVE_LOW>;
		clocks = <&clk26m>;
		clock-names = "xvclk";
		assigned-clock-rates = <24000000>;
		port {
			ov8856_ep: endpoint {
				remote-endpoint = <&seninf_ep1>;
				data-lanes = <1 2>;
				clock-lanes = <0>;
			};
		};
	};

	/* Macro: GC02M1 2MP */
	gc02m1: camera@3c {
		compatible = "galaxycore,gc02m1";
		reg = <0x3c>;
		enable-gpios = <&pinctrl 126 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&pinctrl 127 GPIO_ACTIVE_LOW>;
		clocks = <&clk26m>;
		clock-names = "xvclk";
	};
};

/* SPI0 */
&spi0 {
	status = "okay";
};

/* USB OTG */
&usb {
	dr_mode = "otg";
	status = "okay";
};

/* Thermal sensor */
&thermal {
	status = "okay";
};

/* PWM for backlight */
&pwm0 {
	status = "okay";
};

/* DSI display output */
&dsi {
	status = "okay";

	panel@0 {
		compatible = "tianma,tm6451f", "simple-panel";
		reg = <0>;
		backlight = <&backlight>;
		enable-gpios = <&pinctrl 6 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&pinctrl 5 GPIO_ACTIVE_LOW>;

		port {
			panel_in: endpoint {
				remote-endpoint = <&dsi_out>;
			};
		};
	};

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@1 {
			reg = <1>;
			dsi_out: endpoint {
				remote-endpoint = <&panel_in>;
			};
		};
	};
};

/* GPU */
&mali {
	status = "okay";
};

/* Camera sensor interface */
&seninf {
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@0 {
			reg = <0>;
			seninf_ep0: endpoint {
				remote-endpoint = <&imx686_ep>;
				bus-type = <4>; /* CSI2 DPHY */
				data-lanes = <1 2 3 4>;
				clock-lanes = <0>;
				clock-noncontinuous;
				link-frequencies = /bits/ 64 <297000000>;
			};
		};

		port@1 {
			reg = <1>;
			seninf_ep1: endpoint {
				remote-endpoint = <&ov8856_ep>;
				bus-type = <4>;
				data-lanes = <1 2>;
				clock-lanes = <0>;
				clock-noncontinuous;
				link-frequencies = /bits/ 64 <297000000>;
			};
		};
	};
};

&camsv0 {
	status = "okay";
};
