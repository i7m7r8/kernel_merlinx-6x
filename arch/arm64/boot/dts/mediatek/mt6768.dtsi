/* SPDX-License-Identifier: GPL-2.0 */
/*
 * MediaTek MT6768 SoC device tree source include
 * Comprehensive version with Phase 2 hardware
 */

#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/clock/mt6769-clk.h>
#include <dt-bindings/gpio/gpio.h>

/ {
	model = "MediaTek MT6768";
	compatible = "mediatek,mt6768";
	interrupt-parent = <&gic>;
	#address-cells = <2>;
	#size-cells = <2>;

	chosen {
		bootargs = "console=ttyS0,921600n1 earlycon=uart8250,mmio32,0x11002000,921600n8";
		stdout-path = "uart0:921600n8";
	};

	memory@40000000 {
		device_type = "memory";
		reg = <0 0x40000000 0 0x80000000>;
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x000>;
			enable-method = "psci";
		};
		cpu1: cpu@100 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x100>;
			enable-method = "psci";
		};
		cpu2: cpu@200 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x200>;
			enable-method = "psci";
		};
		cpu3: cpu@300 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x300>;
			enable-method = "psci";
		};
		cpu4: cpu@400 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x400>;
			enable-method = "psci";
		};
		cpu5: cpu@500 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x500>;
			enable-method = "psci";
		};
		cpu6: cpu@600 {
			device_type = "cpu";
			compatible = "arm,cortex-a75";
			reg = <0x600>;
			enable-method = "psci";
		};
		cpu7: cpu@700 {
			device_type = "cpu";
			compatible = "arm,cortex-a75";
			reg = <0x700>;
			enable-method = "psci";
		};
	};

	clocks {
		clk26m: oscillator@0 {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <26000000>;
			clock-output-names = "clk26m";
		};
		clk32k: oscillator@1 {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <32768>;
			clock-output-names = "clk32k";
		};
	};

	soc {
		compatible = "simple-bus";
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		gic: interrupt-controller@0c000000 {
			compatible = "arm,gic-v3";
			reg = <0 0x0c000000 0 0x40000>,
			      <0 0x0c040000 0 0x200000>;
			interrupts = <GIC_PPI 9 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-controller;
			#interrupt-cells = <3>;
		};

		/* UART0 - Serial console */
		uart0: serial@11002000 {
			compatible = "mediatek,mt6577-uart";
			reg = <0 0x11002000 0 0x1000>;
			interrupts = <GIC_SPI 91 IRQ_TYPE_LEVEL_LOW>;
			status = "okay";
		};

		/* UART1 */
		uart1: serial@11003000 {
			compatible = "mediatek,mt6577-uart";
			reg = <0 0x11003000 0 0x1000>;
			interrupts = <GIC_SPI 92 IRQ_TYPE_LEVEL_LOW>;
			status = "disabled";
		};

		/* UART2 */
		uart2: serial@11004000 {
			compatible = "mediatek,mt6577-uart";
			reg = <0 0x11004000 0 0x1000>;
			interrupts = <GIC_SPI 93 IRQ_TYPE_LEVEL_LOW>;
			status = "disabled";
		};

		/* I2C0 */
		i2c0: i2c@11007000 {
			compatible = "mediatek,mt6577-i2c";
			reg = <0 0x11007000 0 0x1000>,
			      <0 0x10217000 0 0x1000>;
			interrupts = <GIC_SPI 44 IRQ_TYPE_LEVEL_LOW>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		/* I2C1 */
		i2c1: i2c@11008000 {
			compatible = "mediatek,mt6577-i2c";
			reg = <0 0x11008000 0 0x1000>,
			      <0 0x10217000 0 0x1000>;
			interrupts = <GIC_SPI 45 IRQ_TYPE_LEVEL_LOW>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		/* I2C2 */
		i2c2: i2c@11009000 {
			compatible = "mediatek,mt6577-i2c";
			reg = <0 0x11009000 0 0x1000>,
			      <0 0x10217000 0 0x1000>;
			interrupts = <GIC_SPI 46 IRQ_TYPE_LEVEL_LOW>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		/* SPI0 */
		spi0: spi@1100a000 {
			compatible = "mediatek,mt6589-spi";
			reg = <0 0x1100a000 0 0x1000>;
			interrupts = <GIC_SPI 111 IRQ_TYPE_LEVEL_LOW>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		/* eMMC/SD controller 0 */
		mmc0: mmc@11230000 {
			compatible = "mediatek,mt2712-mmc";
			reg = <0 0x11230000 0 0x1000>,
			      <0 0x11c20000 0 0x1000>;
			interrupts = <GIC_SPI 74 IRQ_TYPE_LEVEL_LOW>;
			status = "okay";
		};

		/* eMMC/SD controller 1 */
		mmc1: mmc@11240000 {
			compatible = "mediatek,mt2712-mmc";
			reg = <0 0x11240000 0 0x1000>,
			      <0 0x11c30000 0 0x1000>;
			interrupts = <GIC_SPI 75 IRQ_TYPE_LEVEL_LOW>;
			status = "disabled";
		};

		/* eMMC/SD controller 2 */
		mmc2: mmc@11250000 {
			compatible = "mediatek,mt2712-mmc";
			reg = <0 0x11250000 0 0x1000>,
			      <0 0x11c40000 0 0x1000>;
			interrupts = <GIC_SPI 76 IRQ_TYPE_LEVEL_LOW>;
			status = "disabled";
		};

		/* USB 3.0/OTG */
		usb: usb@11200000 {
			compatible = "mediatek,mtk-mtu3";
			reg = <0 0x11200000 0 0x3000>;
			interrupts = <GIC_SPI 64 IRQ_TYPE_LEVEL_LOW>;
			dr_mode = "otg";
			status = "okay";
		};

		/* Infrastructure syscon */
		infracfg: syscon@10001000 {
			compatible = "mediatek,mt6768-infracfg", "syscon";
			reg = <0 0x10001000 0 0x1000>;
		};

		/* Top clock generator syscon */
		topckgen: syscon@10000000 {
			compatible = "mediatek,mt6768-topckgen", "syscon";
			reg = <0 0x10000000 0 0x1000>;
		};

		/* APMixed PLL syscon */
		apmixedsys: syscon@1000c000 {
			compatible = "mediatek,mt6768-apmixedsys", "syscon";
			reg = <0 0x1000c000 0 0x1000>;
		};

		/* Power controller syscon */
		scpsys: syscon@10006000 {
			compatible = "mediatek,mt6768-scpsys", "syscon";
			reg = <0 0x10006000 0 0x1000>;
		};

		/* Pin controller */
		pinctrl: pinctrl@10005000 {
			compatible = "mediatek,mt6768-pinctrl";
			reg = <0 0x10005000 0 0x1000>;
			gpio-controller;
			gpio-ranges = <&pinctrl 0 0 186>;
			#gpio-cells = <2>;
			interrupt-controller;
			interrupts = <GIC_SPI 186 IRQ_TYPE_LEVEL_HIGH>;
			#interrupt-cells = <2>;
		};

		/* PMIC wrapper */
		pwrap: pwrap@1000d000 {
			compatible = "mediatek,mt6768-pwrap";
			reg = <0 0x1000d000 0 0x1000>;
			interrupts = <GIC_SPI 194 IRQ_TYPE_LEVEL_HIGH>;

			pmic: mt6358 {
				compatible = "mediatek,mt6358";
				interrupt-controller;
				#interrupt-cells = <2>;
				interrupts = <144 IRQ_TYPE_LEVEL_HIGH>;
			};
		};

		/* Thermal sensor */
		thermal: thermal@1100b000 {
			compatible = "mediatek,mt2701-thermal";
			reg = <0 0x1100b000 0 0x1000>;
			interrupts = <GIC_SPI 53 IRQ_TYPE_LEVEL_LOW>;
			#thermal-sensor-cells = <1>;
			status = "okay";
		};

		/* Mali GPU */
		mali: gpu@13040000 {
			compatible = "arm,mali-g52";
			reg = <0 0x13040000 0 0x10000>;
			interrupts = <GIC_SPI 220 IRQ_TYPE_LEVEL_HIGH>,
				     <GIC_SPI 221 IRQ_TYPE_LEVEL_HIGH>,
				     <GIC_SPI 222 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-names = "job", "mmu", "gpu";
			status = "disabled";
		};

		/* Display subsystem */
		mmsys: syscon@14000000 {
			compatible = "mediatek,mt6768-mmsys", "syscon";
			reg = <0 0x14000000 0 0x1000>;
		};

		/* DSI output */
		dsi: dsi@14014000 {
			compatible = "mediatek,mt6768-dsi",
				     "mediatek,mt6779-dsi";
			reg = <0 0x14014000 0 0x1000>,
			      <0 0x14015000 0 0x1000>;
			interrupts = <GIC_SPI 210 IRQ_TYPE_LEVEL_LOW>;
			phys = <&mipi_tx0>;
			phy-names = "dphy";
			status = "disabled";
		};

		/* MIPI D-PHY */
		mipi_tx0: mipi-dphy@14012000 {
			compatible = "mediatek,mt6768-mipi-tx",
				     "mediatek,mt6779-mipi-tx";
			reg = <0 0x14012000 0 0x1000>;
			clocks = <&clk26m>;
			clock-output-names = "mipitx_dsi_ck";
			#clock-cells = <0>;
			#phy-cells = <0>;
		};

		/* PWM for backlight */
		pwm0: pwm@1401e000 {
			compatible = "mediatek,mt6768-disp-pwm",
				     "mediatek,mt6779-disp-pwm";
			reg = <0 0x1401e000 0 0x1000>;
			#pwm-cells = <2>;
			status = "disabled";
		};

		/* Camera sensor interface */
		seninf: seninf@15040000 {
			compatible = "mediatek,mt6768-seninf",
				     "mediatek,mt6779-seninf";
			reg = <0 0x15040000 0 0x4000>;
			interrupts = <GIC_SPI 208 IRQ_TYPE_LEVEL_LOW>;
			status = "disabled";
		};

		/* Camera ISP */
		camsv0: camsv@15050000 {
			compatible = "mediatek,mt6768-camsv",
				     "mediatek,mt6779-camsv";
			reg = <0 0x15050000 0 0x1000>;
			interrupts = <GIC_SPI 209 IRQ_TYPE_LEVEL_LOW>;
			status = "disabled";
		};
	};
};
